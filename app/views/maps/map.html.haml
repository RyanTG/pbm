#map_page_body
  - if mobile_device?
    %div.search_mobile
      %div.search_modal{:onclick => "showSearchModal();"}
        %button Search
      - unless current_page?(operators_path)
        #closest_button.hide_button.toggle_btn_reg{:onclick => "findClosestLocations()"} Nearby
  #form_container
    #form
      - if mobile_device?
        %div.close_button{:onclick => "hideSearchModal();"}
          X
      = form_tag map_location_data_path, :method => 'get', :id => 'address_search_form', :class => 'location_search' do
        = hidden_field_tag :by_location_id
        = hidden_field_tag :by_city_name
        = hidden_field_tag :by_state_name
        = hidden_field_tag :by_city_no_state
        = hidden_field_tag :address, params[:address]
        .map_search_row
          .map_search_wrapper
            %input#map_search.lookup_search_input{type: 'text', value: (params['by_location_name'].presence || params['address'].presence).to_s, placeholder: 'Search by location or city...', autocomplete: 'off'}
            #map_search_dropdown.map_search_dropdown{style: 'display: none;'}
          %button#filter_button.toggle_btn_reg{type: 'button', onclick: 'openFilterModal()'}
            Filters
            %span#filter_badge.filter_badge{style: 'display: none;'}
          = image_submit_tag('search_icon.png', class: 'map search', id: 'location_search_button')
        #filter_modal{style: 'display: none;'}
          .filter_modal_overlay{onclick: 'closeFilterModal()'}
          .filter_modal_content
            .filter_modal_header
              %h3 Filters
              %button.filter_modal_close{type: 'button', onclick: 'closeFilterModal()'} ×
            .filter_modal_body
              .filter_group
                %label.filter_label Machine
                %select#machine_select{multiple: true, name: 'machine_filter_ids[]'}
                #single_hide.single_hide{style: 'display: none;'}
                  %input{type: 'checkbox', id: 'singleVersion', name: 'singleVersion', class: 'm_0'}
                  %span Exact machine version?
              .filter_group
                %label.filter_label Manufacturer
                %select#manufacturer_select{multiple: true, name: 'manufacturer[]'}
              .filter_group
                %label.filter_label Location type
                = select_tag "by_type_id[]", options_from_collection_for_select(LocationType.all.sort_by(&:name), 'id', 'name', params["by_type_id"]), multiple: true, id: 'by_type_id'
              .filter_group
                %label.filter_label Min machines
                = select_tag "by_at_least_n_machines", options_for_select([['Any', ''], ['2+', '2'], ['5+', '5'], ['10+', '10'], ['20+', '20']], params['by_at_least_n_machines']), id: 'by_at_least_n_machines'
              .filter_group.filter_check_group
                = check_box_tag 'by_machine_type[]', 'em', Array(params['by_machine_type']).include?('em'), id: 'by_em_only'
                %label{for: 'by_em_only'} EM only
              .filter_group.filter_check_group
                = check_box_tag 'by_ic_active', '1', params['by_ic_active'].present?, id: 'by_ic_active'
                %label{for: 'by_ic_active'} IC active only
            .filter_modal_footer
              %button.filter_clear_btn{type: 'button', onclick: 'clearFilters()'} Clear all
              %button.filter_apply_btn{type: 'button', onclick: 'applyFilters()'} Apply

  #map
    #map_canvas

  - unless mobile_device?
    #closest_button.fixed.hide_button.toggle_btn_reg{:onclick => "findClosestLocations()"} Nearby locations
  #map_activity_button.fixed.hide_button.toggle_btn_reg
    Activity feed
  #refresh_button.fixed.toggle_btn_reg Refresh map area
  - unless mobile_device?
    #key_container.fixed.hide_button.toggle_btn_reg.flex_center
      =image_tag( 'marker-z-1-noShadow.png', :alt => '1 machine example',:style => 'height: 20px;padding-right: 5px;')
      1 machine
      =image_tag( 'marker-z-2-noShadow.png', :alt => '2 machines example',:style => 'height: 20px;padding: 0 5px 0 10px;')
      2-9
      =image_tag( 'marker-z-10-noShadow.png', :alt => '10 machines example',:style => 'height: 20px;padding: 0 5px 0 10px;')
      10+

  %button#top_button{onclick: "topFunction()", title: "Go to top"} Top

  #lookup.map_lookup
    - if (current_page?(map_path) && @map_no_params)
      #intro_container
        = render :partial => 'pages/intro'
    %div#map_activity_container
    #locations

- if (current_page?(map_path) && @map_no_params)
  :javascript
    center_lat = #{@nearby_lat};
    center_lon = #{@nearby_lon};
    map_init = 1;
    map_init_zoom = #{@map_init_zoom};
    homeMapBounds(center_lat, center_lon, map_init, map_init_zoom);

:javascript
  center_lat = #{@nearby_lat};
  center_lon = #{@nearby_lon};
  var savedLocations = "";

  // ---- Unified search autocomplete ----
  var mapSearchInput = document.getElementById('map_search');
  var mapSearchDropdown = document.getElementById('map_search_dropdown');
  var searchDebounce;

  mapSearchInput.addEventListener('input', function() {
    clearTimeout(searchDebounce);
    var term = this.value.trim();
    if (term.length < 3) { mapSearchDropdown.style.display = 'none'; return; }
    searchDebounce = setTimeout(function() {
      fetch('/search/autocomplete?term=' + encodeURIComponent(term))
        .then(function(r) { return r.json(); })
        .then(renderSearchDropdown);
    }, 400);
  });

  document.addEventListener('click', function(e) {
    if (!mapSearchDropdown.contains(e.target) && e.target !== mapSearchInput) {
      mapSearchDropdown.style.display = 'none';
    }
  });

  function escHtml(s) {
    return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  function renderSearchDropdown(results) {
    if (!results.length) { mapSearchDropdown.style.display = 'none'; return; }
    mapSearchDropdown.innerHTML = results.map(function(r) {
      return '<div class="map_search_item" data-type="' + r.type + '" data-id="' + (r.id || '') + '" data-value="' + escHtml(r.value) + '" data-city="' + escHtml(r.city || '') + '" data-state="' + escHtml(r.state || '') + '">' + (r.type === 'location' ? '&#128205; ' : '&#127760; ') + escHtml(r.label) + '</div>';
    }).join('');
    mapSearchDropdown.style.display = 'block';
    mapSearchDropdown.querySelectorAll('.map_search_item').forEach(function(item) {
      item.addEventListener('mousedown', function(e) {
        e.preventDefault();
        selectSearchResult(item);
      });
    });
  }

  function clearSearchHiddenFields() {
    document.getElementById('by_location_id').value = '';
    document.getElementById('by_city_name').value = '';
    document.getElementById('by_state_name').value = '';
    document.getElementById('by_city_no_state').value = '';
  }

  function selectSearchResult(item) {
    clearSearchHiddenFields();
    mapSearchInput.value = item.dataset.value;
    mapSearchDropdown.style.display = 'none';
    if (item.dataset.type === 'location') {
      document.getElementById('by_location_id').value = item.dataset.id;
    } else {
      var city = item.dataset.city;
      var state = item.dataset.state;
      if (state) {
        document.getElementById('by_city_name').value = city;
        document.getElementById('by_state_name').value = state;
      } else {
        document.getElementById('by_city_no_state').value = city;
      }
    }
    document.getElementById('address_search_form').dispatchEvent(new Event('submit', { cancelable: true }));
  }

  function clearAddress() {
    document.getElementById('map_search').value = '';
    clearSearchHiddenFields();
  }

  // ---- Filter modal ----
  function openFilterModal() {
    document.getElementById('filter_modal').style.display = 'flex';
  }

  function closeFilterModal() {
    document.getElementById('filter_modal').style.display = 'none';
  }

  function collectFilterState() {
    var machineValues = machineSelect.getValue();
    var singleVersion = document.getElementById('singleVersion').checked;
    var by_machine_id = [], by_machine_single_id = [];
    if (machineValues.length === 1) {
      var opt = machineSelect.options[machineValues[0]];
      if (opt && opt.group_id && !singleVersion) {
        by_machine_id = machineValues;
      } else {
        by_machine_single_id = machineValues;
      }
    } else if (machineValues.length > 1) {
      by_machine_single_id = machineValues;
    }
    return {
      by_machine_id: by_machine_id,
      by_machine_single_id: by_machine_single_id,
      by_type_id: locationTypeSelect.getValue(),
      by_at_least_n_machines: document.getElementById('by_at_least_n_machines').value,
      by_ic_active: document.getElementById('by_ic_active').checked ? '1' : '',
      by_machine_type: document.getElementById('by_em_only').checked ? ['em'] : [],
      manufacturer: manufacturerSelect.getValue()
    };
  }

  function applyFilters() {
    closeFilterModal();
    var f = collectFilterState();
    window.activeMapFilters = {
      by_ic_active: f.by_ic_active,
      by_machine_type: f.by_machine_type,
      manufacturer: f.manufacturer
    };
    hideSearchModal();
    $('#map_activity_button').css('display', 'block');
    $('#intro_container').css('display', 'none');
    updateFilterBadge();
    getMapBounds(f.by_at_least_n_machines, f.by_type_id, f.by_machine_id, f.by_machine_single_id);
  }

  function clearFilters() {
    machineSelect.clear();
    manufacturerSelect.clear();
    locationTypeSelect.clear();
    document.getElementById('by_at_least_n_machines').value = '';
    document.getElementById('by_em_only').checked = false;
    document.getElementById('by_ic_active').checked = false;
    document.getElementById('single_hide').style.display = 'none';
    document.getElementById('singleVersion').checked = false;
    filterMachinesByManufacturer();
    updateFilterBadge();
  }

  function updateFilterBadge() {
    var f = collectFilterState();
    var count = machineSelect.getValue().length +
                manufacturerSelect.getValue().length +
                locationTypeSelect.getValue().length +
                (f.by_at_least_n_machines ? 1 : 0) +
                (document.getElementById('by_em_only').checked ? 1 : 0) +
                (document.getElementById('by_ic_active').checked ? 1 : 0);
    var badge = document.getElementById('filter_badge');
    if (count > 0) {
      badge.textContent = count;
      badge.style.display = 'inline-flex';
    } else {
      badge.style.display = 'none';
    }
  }

  // ---- Tom Select inits ----
  var allMachineData = #{raw @all_machines_json.to_json};

  var machineSelect = new TomSelect('#machine_select', {
    options: allMachineData,
    valueField: 'value',
    labelField: 'text',
    searchField: 'text',
    items: #{raw @selected_machine_ids.to_json},
    plugins: ['remove_button'],
    closeAfterSelect: true,
    placeholder: '#{j @machine_placeholder}',
    onItemAdd: function() { updateSingleHide(); clearSearchHiddenFields(); updateFilterBadge(); },
    onItemRemove: function() { updateSingleHide(); updateFilterBadge(); }
  });

  var manufacturerSelect = new TomSelect('#manufacturer_select', {
    options: #{raw @all_manufacturers.map { |m| { value: m, text: m } }.to_json},
    valueField: 'value',
    labelField: 'text',
    searchField: 'text',
    items: #{raw Array(params['manufacturer']).to_json},
    plugins: ['remove_button'],
    closeAfterSelect: false,
    placeholder: 'All manufacturers',
    onItemAdd: function() { filterMachinesByManufacturer(); updateFilterBadge(); },
    onItemRemove: function() { filterMachinesByManufacturer(); updateFilterBadge(); }
  });

  var locationTypeSelect = new TomSelect('#by_type_id', {
    plugins: ['remove_button'],
    closeAfterSelect: false,
    placeholder: 'All types',
    onItemAdd: function() { updateFilterBadge(); },
    onItemRemove: function() { updateFilterBadge(); }
  });

  function updateSingleHide() {
    var values = machineSelect.getValue();
    var singleHide = document.getElementById('single_hide');
    var singleVersion = document.getElementById('singleVersion');
    if (values.length === 1) {
      var opt = machineSelect.options[values[0]];
      if (opt && opt.group_id) {
        singleHide.style.display = 'block';
        return;
      }
    }
    singleHide.style.display = 'none';
    singleVersion.checked = false;
  }

  function filterMachinesByManufacturer() {
    var selectedMfrs = manufacturerSelect.getValue();
    var currentItems = machineSelect.getValue();
    machineSelect.clearOptions();
    var filtered = selectedMfrs.length
      ? allMachineData.filter(function(m) { return !m.manufacturer || selectedMfrs.includes(m.manufacturer); })
      : allMachineData;
    machineSelect.addOptions(filtered);
    machineSelect.refreshOptions(false);
    var validSet = new Set(filtered.map(function(m) { return String(m.value); }));
    var stillValid = currentItems.filter(function(id) { return validSet.has(String(id)); });
    if (stillValid.length !== currentItems.length) {
      machineSelect.setValue(stillValid, true);
    }
  }

  // Initialise badge and single_hide for any pre-selected params
  updateSingleHide();
  updateFilterBadge();

  // Set activeMapFilters from any pre-selected params so Refresh works on page load
  window.activeMapFilters = {
    by_ic_active: document.getElementById('by_ic_active').checked ? '1' : '',
    by_machine_type: document.getElementById('by_em_only').checked ? ['em'] : [],
    manufacturer: manufacturerSelect.getValue()
  };

  // ---- Activity feed ----
  var mapActivityFilters = [];

  $(document).on('activity-loaded', function() {
    topFunction();
    mapActivityFilters.forEach(function(filter) {
      $('#map_activity_container .map_activity_filter[value="' + filter + '"]').prop('checked', true);
    });
  });

  $("#map_activity_container").on("click", ".apply_map_activity_filters", function() {
    mapActivityFilters = [];
    $('#map_activity_container .map_activity_filter:checked').each(function() {
      mapActivityFilters.push(this.value);
    });
    loadMapActivity();
  });

  $("#map_activity_container").on("click", "#next_link > nav > a", function(e) {
    e.preventDefault();
    var url = new URL(e.target.href);
    var page = url.searchParams.get("page") || "";
    $('#map_activity_container').html(loadingHTML());
    $.get('/user_submissions/list_within_range', {
      boundsData: getMapBoundsData(),
      page: page,
      submission_type: mapActivityFilters
    }, function(data) {
      $('#map_activity_container').html(data);
    });
  });

  function getMapBoundsData() {
    var bounds = map.getBounds();
    return {
      ne: bounds.getNorthEast(),
      sw: bounds.getSouthWest()
    };
  }

  function loadMapActivity() {
    $('#map_activity_container').html(loadingHTML());
    $.get('/user_submissions/list_within_range', {
      boundsData: getMapBoundsData(),
      submission_type: mapActivityFilters
    }, function(data, textStatus, jqxhr) {
      $('#map_activity_container').html(data);
    });
  }

  $('#map_activity_button').bind('click', function(event, ui) {
    if ($('#map_activity_container').html().trim() !== '') {
      $('#map_activity_container').html('');
    } else {
      savedLocations = $('#map_activity_container').html;
      $('#intro_container').css('display', 'none');
      loadMapActivity();
    }
    return false;
  });

  document.getElementById("refresh_button").addEventListener("click", function() {
    var f = collectFilterState();
    window.activeMapFilters = {
      by_ic_active: f.by_ic_active,
      by_machine_type: f.by_machine_type,
      manufacturer: f.manufacturer
    };
    $('#intro_container').css('display', 'none');
    var mapActivityVisible = $('#map_activity_container').html().trim() !== '';
    getMapBounds(f.by_at_least_n_machines, f.by_type_id, f.by_machine_id, f.by_machine_single_id);
    clearAddress();
    if (mapActivityVisible) {
      loadMapActivity();
    }
  });

  $('#address_search_form').on('submit', function(e) {
    e.preventDefault();
    var f = collectFilterState();
    window.activeMapFilters = {
      by_ic_active: f.by_ic_active,
      by_machine_type: f.by_machine_type,
      manufacturer: f.manufacturer
    };
    var machineParams = '';
    if (f.by_machine_id.length === 1) {
      machineParams = '&by_machine_id[]=' + f.by_machine_id[0];
    } else {
      f.by_machine_single_id.forEach(function(id) {
        machineParams += '&by_machine_single_id[]=' + id;
      });
    }
    hideSearchModal();
    mapAdjusted = 0;
    $('#map_activity_button').css('display', 'block');
    $('#intro_container,#map_activity').css('display', 'none');
    var form = $(this);
    var formAction = form.attr('action');
    var formData = form.serialize();
    lastSearchFn = function() {
      $('#locations').html(loadingHTML());
      $.get(formAction, formData + machineParams + '&sort=' + currentSort, function(data, textStatus, jqxhr) {
        $('#locations').html(data);
      });
    };
    lastSearchFn();
    return false;
  });
